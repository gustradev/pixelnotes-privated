# =========================================================
# PIXEL NOTES - ENVIRONMENT CONFIGURATION
# =========================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =========================================================

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
FRONTEND_PORT=94837
API_BASE_URL=https://api94837.pixelsolusindo.space

# ===========================================
# BACKEND CONFIGURATION
# ===========================================
BACKEND_PORT=94838

# Secret Entry Password (for accessing hidden chat mode)
SECRET_ENTRY_PASSWORD=your_secret_entry_password_here

# ===========================================
# SECRET CHAT USERS (Only 2 Static Users)
# ===========================================
# User 1
SECRET_USER_1=user_alpha
SECRET_PASS_1=$2b$12$your_bcrypt_hashed_password_here

# User 2
SECRET_USER_2=user_beta
SECRET_PASS_2=$2b$12$your_bcrypt_hashed_password_here

# ===========================================
# JWT CONFIGURATION
# ===========================================
JWT_SECRET=your_super_secret_jwt_key_at_least_64_chars_long_random_string_here
JWT_EXPIRY_HOURS=2

# ===========================================
# ENCRYPTION KEY (AES-256-GCM)
# ===========================================
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_SECONDS=86400

# ===========================================
# CLOUDFLARE TUNNEL CONFIGURATION
# ===========================================
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
CF_TUNNEL_ID=your_tunnel_id_here
CF_HOST_NOTE=note.pixelsolusindo.space
CF_HOST_API=api94837.pixelsolusindo.space

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ORIGINS=https://note.pixelsolusindo.space

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
